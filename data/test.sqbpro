<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="/Users/maze/Desktop/Hyper Menu/Files/Programming/Rust/Project Manager/Current Projects/web_api_data/data/test.db" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="0"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="881"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><current_table name="4,11:mainleaderboard"/><default_encoding codec=""/><browse_table_settings><table schema="main" name="leaderboard" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_"><sort/><column_widths><column index="1" value="43"/><column index="2" value="96"/><column index="3" value="41"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="users" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_"><sort/><column_widths><column index="1" value="61"/><column index="2" value="85"/><column index="3" value="21"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1">SELECT UserID, pk,

CASE
WHEN IScore = 0 THEN RScore
WHEN IScore &gt; 0 THEN RScore || ' + ' || IScore
WHEN IScore &lt; 0 THEN RScore || ' - ' || IScore
END AS Score
 , username
        FROM leaderboard  l
        LEFT JOIN users u ON u.pk = l.UserID
        ORDER BY l.RScore DESC, l.IScore DESC
        LIMIT 10
		</sql><current_tab id="0"/></tab_sql></sqlb_project>
